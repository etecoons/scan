<?xml version="1.0"?>
<Container version="2">
  <Name>scan</Name>
  <Repository>ghcr.io/studio2201/scan:latest</Repository>
  <Registry>https://ghcr.io/studio2201/scan</Registry>
  <Network>bridge</Network>
  <MyIP/>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/studio2201/scan/issues</Support>
  <Project>https://github.com/studio2201/scan</Project>
  <Overview>Secure self-hosted web network scanner and port diagnostics utility built in Rust.</Overview>
  <Category>Game:Arcade Game:Puzzle Network:Web</Category>
  <WebUI>http://[IP]:[PORT:4503]/</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/studio2201/unraid-templates/master/templates/scan.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/studio2201/unraid-templates/master/icons/scan.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <CPUset/>
  <DateInstalled/>
  <DonateText/>
  <DonateLink/>
  <Description>Secure self-hosted web network scanner and port diagnostics utility built in Rust.</Description>
  <Networking>
    <Mode>bridge</Mode>
    <Publish>
      <Port>
        <HostPort>4503</HostPort>
        <ContainerPort>4503</ContainerPort>
        <Protocol>tcp</Protocol>
      </Port>
    </Publish>
  </Networking>
  <Data>
    <Volume>
      <HostDir>/mnt/user/appdata/scan</HostDir>
      <ContainerDir>/config</ContainerDir>
      <Mode>rw</Mode>
    </Volume>
  </Data>
  <Environment>
    <Variable>
      <Value>4503</Value>
      <Name>PORT</Name>
      <Mode/>
    </Variable>
    <Variable>
      <Value>/config</Value>
      <Name>DATA_DIR</Name>
      <Mode/>
    </Variable>
  </Environment>
  <Labels/>
  <Config Name="Web UI Port" Target="4503" Default="4503" Mode="tcp" Description="HTTP Web Interface Port" Type="Port" Display="always" Required="true" Mask="false">4503</Config>
  <Config Name="App Storage Directory" Target="/config" Default="/mnt/user/appdata/scan" Mode="rw" Description="Persistent data and configuration directory" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/scan</Config>
</Container>
